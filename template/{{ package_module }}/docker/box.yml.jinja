name: {{package_name}}-box
services:
  {{package_name}}-box:
    # image: "geerlingguy/docker-ubuntu2404-ansible:latest"
    "us-central1-docker.pkg.dev/alpha29-bfx/alpha29/base:0.2.0"
    container_name: {{package_name}}-box
    ports:
      - "8200:8200"
    volumes:
      # host_directory:docker_directory
      - "/sys/fs/cgroup:/sys/fs/cgroup:rw"
      #- "../:/root/uv-whaler"
    privileged: true
    hostname: "{{package_name}}-box"
    #command: tail -f /dev/null
    command: /lib/systemd/systemd
    working_dir: /workspace/
    cgroup: host
