from {{package_module}}.settings import settings


def test_settings():
    print("Loading settings...")
    print(settings.model_dump())  # Print all settings
    assert settings.logging.log_level == "INFO"
    assert settings.logging.log_to_file is True
    assert settings.logging.log_file == "./log/{{package_module}}.log"
    assert settings.{{package_module | upper}}_HOME is not None
    assert settings.{{package_module | upper}}_OPTIONS is not None
    assert settings.{{package_module | upper}}_HOME.exists()
    assert settings.{{package_module | upper}}_OPTIONS.exists()
    assert settings.{{package_module | upper}}_HOME.is_dir()
    assert settings.{{package_module | upper}}_OPTIONS.is_file()
    assert settings.jupyter.notebook_port == 8888
